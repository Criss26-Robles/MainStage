# Conexión a PostgreSQL local (ajusta usuario, contraseña, host, puerto y base de datos)
DATABASE_URL="postgresql://postgres:TU_PASSWORD@localhost:5432/mainstage?schema=public"

# Secreto para firmar los JWT (cámbialo en producción por un valor largo y aleatorio)
JWT_SECRET="mainstage-dev-secret-change-in-production"

# Puerto del servidor de la API
PORT=3001
