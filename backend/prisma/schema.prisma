generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password      String
  role          String   @default("user")
  presaleAccess Boolean  @default(false)
  createdAt     DateTime @default(now())
  orders        Order[]
  resalesSold   Resale[] @relation("ResaleSeller")
  resalesBought Resale[] @relation("ResaleBuyer")
}

model Event {
  id               Int          @id @default(autoincrement())
  title            String
  artist           String
  category         String
  date             String
  time             String
  venue            String
  city             String
  department       String
  price            Int
  image            String
  imageFocusX      Int          @default(50)
  imageFocusY      Int          @default(50)
  description      String
  availableTickets Int
  featured         Boolean      @default(false)
  popular          Boolean      @default(false)
  discount          Int          @default(0)
  serviceFeePercent Int          @default(10)
  salePhase         String       @default("general")
  tags              String[]
  createdAt         DateTime     @default(now())
  orders           Order[]
  tiers            TicketTier[]
  priceHistory     PriceHistory[]
}

model TicketTier {
  id          Int         @id @default(autoincrement())
  eventId     Int
  name        String
  price       Int
  available   Int
  description String      @default("")
  sortOrder   Int         @default(0)
  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
}

model Order {
  id               Int         @id @default(autoincrement())
  userId           Int
  eventId          Int
  eventTitle       String
  eventCity        String
  eventDate        String
  quantity         Int
  buyerName        String
  buyerEmail       String
  totalPrice       Int
  confirmationCode String
  qrCode           String      @unique
  qrUsed           Boolean     @default(false)
  qrUsedAt         DateTime?
  status           String      @default("active")
  resoldToUserId   Int?
  createdAt        DateTime    @default(now())
  user             User        @relation(fields: [userId], references: [id])
  event            Event       @relation(fields: [eventId], references: [id])
  items            OrderItem[]
  resale           Resale?
}

model OrderItem {
  id             Int         @id @default(autoincrement())
  orderId        Int
  tierId         Int?
  tierName       String
  unitPrice      Int
  serviceFee     Int         @default(0)
  finalUnitPrice Int         @default(0)
  quantity       Int
  subtotal       Int
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tier      TicketTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)
}

model Resale {
  id        Int       @id @default(autoincrement())
  orderId   Int       @unique
  sellerId  Int
  buyerId   Int?
  askPrice  Int
  status    String    @default("listed")
  createdAt DateTime  @default(now())
  soldAt    DateTime?
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  seller    User      @relation("ResaleSeller", fields: [sellerId], references: [id])
  buyer     User?     @relation("ResaleBuyer", fields: [buyerId], references: [id])
}

model PriceHistory {
  id        Int      @id @default(autoincrement())
  eventId   Int
  oldPrice  Int
  newPrice  Int
  reason    String   @default("")
  changedBy Int?
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Venue {
  id          Int    @id @default(autoincrement())
  name        String
  city        String
  department  String
  capacity    Int
  image       String
  description String
  eventCount  Int    @default(0)
}
